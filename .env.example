# Application
PORT=8080
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION_HOURS=24

# Use either DATABASE_URL or the split DB_* variables below.
# DATABASE_URL=postgres://admin:root@localhost:5432/blog?sslmode=disable

DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=root
DB_NAME=blog
DB_SSLMODE=disable
