            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                }
            }
        },
        "github_com_user_simple-blog_internal_modules_auth_domain.LoginResponse": {
            "type": "object",
