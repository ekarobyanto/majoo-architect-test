                "password",
                "username"
            ],
            "properties": {
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string",
                    "minLength": 8
                },
                "username": {
                    "type": "string",
                    "maxLength": 50,
                    "minLength": 3
                }
            }
        },
        "github_com_user_simple-blog_internal_modules_auth_domain.RegisterResponse": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "github_com_user_simple-blog_internal_modules_health_domain.HealthResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        },
        "github_com_user_simple-blog_internal_platform_errors.AppError": {
            "type": "object",
            "properties": {
                "code": {
                    "$ref": "#/definitions/github_com_user_simple-blog_internal_platform_errors.ErrorCode"
                },
                "details": {},
                "message": {
                    "type": "string"
                }
            }
        },
        "github_com_user_simple-blog_internal_platform_errors.ErrorCode": {
            "type": "string",
            "enum": [
                "INTERNAL_ERROR",
                "NOT_FOUND",
                "BAD_REQUEST",
                "UNAUTHORIZED",
                "FORBIDDEN",
                "UNPROCESSABLE_ENTITY",
                "CONFLICT"
            ],
            "x-enum-varnames": [
                "CodeInternal",
                "CodeNotFound",
                "CodeBadRequest",
                "CodeUnauthorized",
                "CodeForbidden",
                "CodeUnprocessable",
                "CodeConflict"
            ]
        },
        "github_com_user_simple-blog_internal_platform_errors.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "$ref": "#/definitions/github_com_user_simple-blog_internal_platform_errors.AppError"
                },
                "success": {
                    "type": "boolean"
                }
            }
        },
        "github_com_user_simple-blog_internal_platform_response.Response": {
            "type": "object",
            "properties": {
                "data": {},
                "message": {
                    "type": "string"
                },
                "meta": {},
